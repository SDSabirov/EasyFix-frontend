# Nuxt Frontend Environment Variables
# Local dev: copy to .env. For Cloudflare Pages set these in the dashboard
# under Settings -> Environment variables (Production and Preview scopes,
# Build phase — they are baked into the client bundle).

# Google Maps API Key (baked into the client at build time)
MAPS_API=your_google_maps_api_key_here

# API Configuration
# For local development: http://127.0.0.1:8000/api
# For production: https://api.easyfixappliance.com/api
NUXT_PUBLIC_API_BASE_URL=https://api.easyfixappliance.com/api

# Nitro preset. Defaults to cloudflare-pages via nuxt.config.ts.
# Override to node-server for the legacy PM2 / ecosystem.config.js setup.
# NITRO_PRESET=cloudflare-pages
